{
  "name": "情绪推荐功能测试",
  "description": "验证进入发布器后系统能够自动推荐情绪标签的功能",
  "priority": "medium",
  "tags": [
    "情绪推荐",
    "发布器",
    "功能测试"
  ],
  "applications": [
    "网易小蜜蜂"
  ],
  "steps": [
    {
      "stepNumber": 1,
      "action": "intelligent-tap",
      "description": "点击首页底部发布按钮进入发布器",
      "params": {
        "prompt": "点击底部中间的发布按钮或加号按钮"
      }
    },
    {
      "stepNumber": 2,
      "action": "wait",
      "description": "等待发布器页面加载完成",
      "params": {
        "ms": 2000
      }
    },
    {
      "stepNumber": 3,
      "action": "intelligent-assert",
      "description": "验证已进入发布器页面",
      "params": {
        "assertion": "页面显示发布器界面，包含发布笔记按钮或正文输入区域"
      }
    },
    {
      "stepNumber": 4,
      "action": "intelligent-tap",
      "description": "选择图片进入发布器",
      "params": {
        "prompt": "点击相册中的第一张图片或选择图片"
      }
    },
    {
      "stepNumber": 5,
      "action": "wait",
      "description": "等待图片加载完成",
      "params": {
        "ms": 1500
      }
    },
    {
      "stepNumber": 6,
      "action": "intelligent-tap",
      "description": "确认选择图片进入编辑页面",
      "params": {
        "prompt": "点击下一步或确认按钮完成图片选择"
      }
    },
    {
      "stepNumber": 7,
      "action": "wait",
      "description": "等待发布器编辑页面加载",
      "params": {
        "ms": 2000
      }
    },
    {
      "stepNumber": 8,
      "action": "intelligent-assert",
      "description": "验证发布器页面已加载且显示标记情绪入口",
      "params": {
        "assertion": "页面显示标记情绪按钮或情绪标签区域"
      }
    },
    {
      "stepNumber": 9,
      "action": "tap",
      "description": "点击标记情绪按钮",
      "elementRef": {
        "page": "发布器-默认",
        "name": "标记情绪"
      }
    },
    {
      "stepNumber": 10,
      "action": "wait",
      "description": "等待情绪推荐加载",
      "params": {
        "ms": 2000
      }
    },
    {
      "stepNumber": 11,
      "action": "intelligent-assert",
      "description": "验证情绪推荐功能正常显示",
      "params": {
        "assertion": "页面显示情绪选择面板或推荐的情绪标签列表，包含多个可选情绪选项"
      }
    },
    {
      "stepNumber": 12,
      "action": "intelligent-assert",
      "description": "验证系统已自动推荐情绪标签",
      "params": {
        "assertion": "情绪面板中显示推荐的情绪标签，或有高亮显示的默认推荐情绪"
      }
    },
    {
      "stepNumber": 13,
      "action": "intelligent-tap",
      "description": "选择一个推荐的情绪标签",
      "params": {
        "prompt": "点击情绪面板中的任意一个情绪标签"
      }
    },
    {
      "stepNumber": 14,
      "action": "wait",
      "description": "等待情绪选择生效",
      "params": {
        "ms": 1000
      }
    },
    {
      "stepNumber": 15,
      "action": "intelligent-assert",
      "description": "验证情绪标签已成功添加到发布内容",
      "params": {
        "assertion": "发布器页面显示已选择的情绪标签，或标记情绪区域显示选中的情绪"
      }
    },
    {
      "stepNumber": 16,
      "action": "tap",
      "description": "点击返回按钮退出发布器",
      "elementRef": {
        "page": "发布器-默认",
        "name": "返回"
      }
    },
    {
      "stepNumber": 17,
      "action": "wait",
      "description": "等待退出确认弹窗",
      "params": {
        "ms": 1000
      }
    },
    {
      "stepNumber": 18,
      "action": "intelligent-tap",
      "description": "确认退出发布器",
      "params": {
        "prompt": "点击确认退出或不保存按钮"
      }
    }
  ],
  "minAppVersion": null,
  "recordedAppVersion": null,
  "blueprintEnabled": false
}